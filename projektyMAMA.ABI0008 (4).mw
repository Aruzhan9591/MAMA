<Text-field prompt="&gt; " style="Maple Input" layout="Normal"></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">Kalendar := module()</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">    export denVTydnu, prestupnyRok, napoveda;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">    option package;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">    # Procedura pro overeni prestupneho roku</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">    prestupnyRok := proc(rok)</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">        if irem(rok,400)=0 then</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">            return true;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">        elif irem(rok,100)=0 then</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">            return false;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">        elif irem(rok,4)=0 then</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">            return true;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">        else</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">            return false;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">        end if;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">    end proc;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">    # Procedura pro urceni dne v tydnu</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">    denVTydnu := proc(den, mesic, rok)</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">        local a, y, m, h, nazvy_dnu, dnyVMesici;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">        # kontrola roku</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">        if rok &lt; 1 then</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">            error &quot;Rok musi byt kladne cele cislo&quot;;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">        end if;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">        # kontrola mesice</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">        if mesic &lt; 1 or mesic &gt; 12 then</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">            error &quot;Mesic musi byt cislo od 1 do 12&quot;;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">        end if;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">        # pocty dni v mesicich</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">        dnyVMesici := Array(1..12, [31,28,31,30,31,30,31,31,30,31,30,31]);</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">        # prestupny rok ma unor 29 dni</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">        if prestupnyRok(rok) then</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">            dnyVMesici[2] := 29;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">        end if;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">        # kontrola dne</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">        if den &lt; 1 or den &gt; dnyVMesici[mesic] then</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">            error &quot;Neplatne datum&quot;;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">        end if;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">        # Zelleruv vzorec pro vypocet dne v tydnu</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">        if mesic &lt;= 2 then</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">            m := mesic + 12;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">            y := rok - 1;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">        else</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">            m := mesic;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">            y := rok;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">        end if;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">        a := iquo(y,100);</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">        h := irem(den + iquo(13*(m+1),5) + y + iquo(y,4) - a + iquo(a,4), 7);</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">        # Nazvy dnu - index 0 = sobota, 1 = nedele, ..., 6 = patek</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">        nazvy_dnu := [&quot;sobota&quot;,&quot;nedele&quot;,&quot;pondeli&quot;,&quot;utery&quot;,&quot;streda&quot;,&quot;ctvrtek&quot;,&quot;patek&quot;];</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">        return nazvy_dnu[h + 1];</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">    end proc;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">    # Napoveda k modulu</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">    napoveda := proc()</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"><Font encoding="UTF-8">        printf(&quot;\134n========================================\134n&quot;);</Font></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"><Font encoding="UTF-8">        printf(&quot;Napoveda k projektu c. 10\134n&quot;);</Font></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"><Font encoding="UTF-8">        printf(&quot;========================================\134n&quot;);</Font></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"><Font encoding="UTF-8">        printf(&quot;denVTydnu(den, mesic, rok) - vrati den v tydnu pro zadane datum\134n&quot;);</Font></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"><Font encoding="UTF-8">        printf(&quot;priklad: denVTydnu(19, 4, 2026) -&gt; nedele\134n&quot;);</Font></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"><Font encoding="UTF-8">        printf(&quot;prestupnyRok(rok) - overi, zda je rok prestupny\134n&quot;);</Font></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"><Font encoding="UTF-8">        printf(&quot;Rok je prestupny, pokud je delitelny 4, ale roky delitelne 100\134n&quot;);</Font></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"><Font encoding="UTF-8">        printf(&quot;jsou prestupne pouze tehdy, kdyz jsou delitelne 400.\134n&quot;);</Font></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"><Font encoding="UTF-8">        printf(&quot;========================================\134n&quot;);</Font></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">    end proc;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">end module:</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"># Nacteni modulu</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">with(Kalendar):</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"># Vypis testovacich vysledku</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"><Font encoding="UTF-8">printf(&quot;\134n========== VYSLEDKY TESTOVANI ==========\134n\134n&quot;);</Font></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"><Font encoding="UTF-8">printf(&quot;1. 19.4.2026 -&gt; %s\134n&quot;, denVTydnu(19, 4, 2026));</Font></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"><Font encoding="UTF-8">printf(&quot;2. 1.1.2023 -&gt; %s\134n&quot;, denVTydnu(1, 1, 2023));</Font></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"><Font encoding="UTF-8">printf(&quot;3. 24.12.2024 -&gt; %s\134n&quot;, denVTydnu(24, 12, 2024));</Font></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"><Font encoding="UTF-8">printf(&quot;4. 29.2.2020 -&gt; %s\134n\134n&quot;, denVTydnu(29, 2, 2020));</Font></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"><Font encoding="UTF-8">printf(&quot;5. Rok 2012 je prestupny? %a\134n&quot;, prestupnyRok(2012));</Font></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"><Font encoding="UTF-8">printf(&quot;6. Rok 2100 je prestupny? %a\134n&quot;, prestupnyRok(2100));</Font></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"><Font encoding="UTF-8">printf(&quot;7. Rok 2000 je prestupny? %a\134n\134n&quot;, prestupnyRok(2000));</Font></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"># Vypis napovedy</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">napoveda();</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"><Font encoding="UTF-8">printf(&quot;\134n========== KONEC PROJEKTU ==========\134n&quot;);</Font></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"> </Text-field>
</Input>
<Output>
<Text-field style="Line Printed Output" layout="Line Printed Output">
